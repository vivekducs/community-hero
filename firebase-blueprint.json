{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile document containing credibility score, authority privileges, gamification points, and tier metrics",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "location": { "type": "object" },
        "zone": { "type": "string" },
        "credibility_score": { "type": "integer" },
        "total_issues_reported": { "type": "integer" },
        "badges_earned": { "type": "array" },
        "is_authority": { "type": "boolean" },
        "department_id": { "type": "string" },
        "total_points": { "type": "integer" },
        "tier": { "type": "string", "enum": ["New", "Active", "Trusted"] },
        "created_at": { "type": "string" }
      },
      "required": ["user_id", "email", "name", "credibility_score", "total_issues_reported", "badges_earned", "created_at"]
    },
    "Issue": {
      "title": "Issue",
      "description": "Civic issue submitted by citizen sentinel",
      "type": "object",
      "properties": {
        "issue_id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "image_urls": { "type": "array" },
        "location": { "type": "object" },
        "category": { "type": "string" },
        "subcategory": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "confidence": { "type": "number" },
        "status": { "type": "string", "enum": ["reported", "verifying", "verified", "investigating", "resolving", "resolved", "dismissed"] },
        "department": { "type": "string" },
        "assigned_to_person": { "type": "string" },
        "created_by": { "type": "string" },
        "created_by_name": { "type": "string" },
        "upvotes": { "type": "integer" },
        "downvotes": { "type": "integer" },
        "verification_percentage": { "type": "number" },
        "escalation_level": { "type": "integer" },
        "created_at": { "type": "string" }
      },
      "required": ["issue_id", "title", "description", "image_urls", "location", "category", "subcategory", "severity", "confidence", "status", "department", "created_by", "upvotes", "downvotes", "verification_percentage", "escalation_level", "created_at"]
    },
    "Verification": {
      "title": "Verification",
      "description": "Citizen confirmation or rejection vote on an issue",
      "type": "object",
      "properties": {
        "verification_id": { "type": "string" },
        "issue_id": { "type": "string" },
        "user_id": { "type": "string" },
        "status": { "type": "string", "enum": ["confirm", "reject"] },
        "comments": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "required": ["verification_id", "issue_id", "user_id", "status", "created_at"]
    },
    "Badge": {
      "title": "Badge",
      "description": "Gamified badge earned by citizens",
      "type": "object",
      "properties": {
        "badge_id": { "type": "string" },
        "user_id": { "type": "string" },
        "badge_type": { "type": "string" },
        "earned_at": { "type": "string" },
        "issue_id": { "type": "string" }
      },
      "required": ["badge_id", "user_id", "badge_type", "earned_at"]
    },
    "Leaderboard": {
      "title": "Leaderboard",
      "description": "Pre-calculated monthly rankings",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "period": { "type": "string" },
        "entries": { "type": "array" },
        "last_updated": { "type": "string" }
      },
      "required": ["type", "period", "entries", "last_updated"]
    },
    "AdminNote": {
      "title": "AdminNote",
      "description": "Internal municipal progress updates, visible to authorities only",
      "type": "object",
      "properties": {
        "note_id": { "type": "string" },
        "issue_id": { "type": "string" },
        "author_id": { "type": "string" },
        "text": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "required": ["note_id", "issue_id", "author_id", "text", "created_at"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User accounts collection"
    },
    "issues/{issueId}": {
      "schema": { "$ref": "#/entities/Issue" },
      "description": "Civic issues collection"
    },
    "verifications/{verificationId}": {
      "schema": { "$ref": "#/entities/Verification" },
      "description": "Civic issue verifications collection"
    },
    "badges/{badgeId}": {
      "schema": { "$ref": "#/entities/Badge" },
      "description": "Earned badges collection"
    },
    "leaderboards/{leaderboardId}": {
      "schema": { "$ref": "#/entities/Leaderboard" },
      "description": "Leaderboard snapshots collection"
    },
    "admin_notes/{noteId}": {
      "schema": { "$ref": "#/entities/AdminNote" },
      "description": "Internal municipal authority notes collection"
    }
  }
}
